    {
      "name": "1. Food Management",
      "item": [
        {
          "name": "Create Food Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Chicken Breast\",\n  \"category\": \"MEAT\",\n  \"brand\": \"Organic Farms\",\n  \"calories\": 165,\n  \"proteinG\": 31,\n  \"carbsG\": 0,\n  \"fatG\": 3.6,\n  \"fiberG\": 0,\n  \"sugarG\": 0,\n  \"sodiumMg\": 74,\n  \"cholesterolMg\": 85,\n  \"saturatedFatG\": 1,\n  \"transFatG\": 0,\n  \"servingSize\": \"1 breast\",\n  \"servingWeightG\": 174,\n  \"barcode\": \"1234567890123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/nutrition/foods",
              "host": ["{{base_url}}"],
              "path": ["nutrition", "foods"]
            }
          }
        },
        {
          "name": "List Foods",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/nutrition/foods?name=chicken&category=MEAT&brand=Organic",
